# ── Sightengine AI Detection API ──────────────────────────────────────────────
# Sign up free at https://sightengine.com  (500 ops/month free)
SIGHTENGINE_API_USER=1101506406
SIGHTENGINE_API_SECRET=bmD92T8wi7SiDjeXqJFEk9GcrDyyfmCg

# ── Firebase ───────────────────────────────────────────────────────────────────
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → save the JSON file
# 3. Set the path to that file below (or paste the raw JSON as a single-line string)
FIREBASE_SERVICE_ACCOUNT=cloudlab-eb9e3-firebase-adminsdk-fbsvc-6c132fd905.json

# Your Storage bucket — found in Firebase Console → Storage
# Format: <project-id>.appspot.com
FIREBASE_STORAGE_BUCKET=cloudlab-eb9e3.firebasestorage.app

# ── Cloud Function (optional) ─────────────────────────────────────────────────
# After deploying functions/main.py, paste the trigger URL here.
# If left empty, detection runs locally and results still save to Firestore.
# Example: https://us-central1-your-project-id.cloudfunctions.net/detect_image
CLOUD_FUNCTION_URL=